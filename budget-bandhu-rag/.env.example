# BudgetBandhu Financial Cognitive OS — Environment Variables
# Copy this to .env and fill in your values before running.

# ─────────────────────────────────────────────────────────────────────
# MONGODB ATLAS (required for Tiers 2-5)
# ─────────────────────────────────────────────────────────────────────
# Get from Atlas UI → Database → Connect → Drivers → Python
MONGODB_ATLAS_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority&appName=BudgetBandhu

# Database name (leave as-is for new installs)
MONGODB_DATABASE=budget_bandhu

# ─────────────────────────────────────────────────────────────────────
# SQLITE (Tier 1 — Working Memory Only)
# ─────────────────────────────────────────────────────────────────────
SQLITE_PATH=working_memory.db

# ─────────────────────────────────────────────────────────────────────
# OLLAMA (LLM)
# ─────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# ─────────────────────────────────────────────────────────────────────
# EMBEDDING MODEL
# ─────────────────────────────────────────────────────────────────────
# all-MiniLM-L6-v2 produces 384-dim embeddings — matches Atlas Vector Search index
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ─────────────────────────────────────────────────────────────────────
# ATLAS SEARCH INDEX NAMES (must match Atlas UI exactly)
# ─────────────────────────────────────────────────────────────────────
ATLAS_VECTOR_INDEX_NAME=episodic_vector_index
ATLAS_TEXT_INDEX_NAME=episodic_text_index

# ─────────────────────────────────────────────────────────────────────
# FASTAPI
# ─────────────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=false
